<%- include('partials/header') %>

<div id="alert-container"></div>

<div class="stats-grid" style="grid-template-columns: 2fr 1fr;">
  
  <!-- Lista de Fluxos de Mensagens -->
  <div style="display:flex; flex-direction:column; gap:30px;">
    
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Seus Fluxos de Mensagens</h3>
      </div>
      
      <div id="flows-container" style="display:flex; flex-direction:column; gap:15px;">
        <p style="text-align: center; color: var(--text-secondary); padding: 20px 0;">Carregando fluxos de mensagens...</p>
      </div>
    </div>
    
  </div>

  <!-- Criador de Novo Fluxo -->
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">Criar Novo Programa/Fluxo</h3>
    </div>
    <form id="create-flow-form">
      <div class="form-group">
        <label for="flow-account">Conta do Mercado Livre</label>
        <select id="flow-account" class="form-control" required>
          <option value="">Selecione uma conta...</option>
          <% accounts.forEach(acc => { %>
            <option value="<%= acc.id %>"><%= acc.nickname %></option>
          <% }) %>
        </select>
      </div>
      
      <div class="form-group">
        <label for="flow-name">Nome do Programa/Fluxo</label>
        <input type="text" id="flow-name" class="form-control" placeholder="Ex: Corel Draw 2026" required>
      </div>

      <div class="form-group">
        <label for="flow-product-id">ID do Anúncio/Produto (MLB...)</label>
        <input type="text" id="flow-product-id" class="form-control" placeholder="Ex: MLB2077665752" required>
        <small style="color: var(--text-secondary); display:block; margin-top:5px; font-size:12px;">
          Insira o ID exato do anúncio no Mercado Livre correspondente a este fluxo.
        </small>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        Criar Fluxo
      </button>
    </form>
  </div>

</div>

<script>
  const flowsContainer = document.getElementById('flows-container');
  const createFlowForm = document.getElementById('create-flow-form');

  // Alertas
  const showAlert = (message, type = 'success') => {
    const container = document.getElementById('alert-container');
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type === 'success' ? 'success' : 'error'}`;
    alertDiv.innerHTML = `<span>${message}</span><button onclick="this.parentElement.remove()" style="background:none; border:none; color:inherit; font-size:16px; cursor:pointer;">×</button>`;
    container.appendChild(alertDiv);
    setTimeout(() => alertDiv.remove(), 4000);
  };

  // Toggle do Accordion
  const toggleAccordion = (header) => {
    const currentItem = header.parentElement;
    const allItems = document.querySelectorAll('.accordion-item');
    
    allItems.forEach(item => {
      if (item !== currentItem) {
        item.classList.remove('active');
      }
    });
    
    currentItem.classList.toggle('active');
  };

  // Carregar todos os fluxos
  const loadFlows = async () => {
    try {
      const response = await fetch('/api/flows');
      if (!response.ok) throw new Error();
      const flows = await response.json();

      if (flows.length === 0) {
        flowsContainer.innerHTML = `<p style="text-align: center; color: var(--text-secondary); padding: 40px 0;">Nenhum fluxo de mensagem cadastrado ainda. Crie um ao lado.</p>`;
        return;
      }

      flowsContainer.innerHTML = flows.map(flow => `
        <div class="accordion-item" id="flow-item-${flow.id}">
          
          <!-- Cabeçalho do Accordion -->
          <div class="accordion-header" onclick="toggleAccordion(this)">
            <div class="accordion-header-title">
              <svg class="accordion-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
              <span>${flow.name}</span>
              <span class="badge badge-info" style="font-size:11px; padding:3px 8px;">Conta: ${flow.account_nickname}</span>
            </div>
            <div style="display:flex; align-items:center; gap:12px;">
              <span style="color:var(--text-secondary); font-size:13px;">
                <strong>Anúncio:</strong> <code>${flow.product_id || flow.product_keywords || ''}</code>
              </span>
              <button onclick="event.stopPropagation(); deleteFlow(${flow.id})" class="btn btn-danger btn-sm" style="padding:4px 10px; display:inline-flex; align-items:center;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                Excluir
              </button>
            </div>
          </div>

          <!-- Conteúdo do Accordion -->
          <div class="accordion-content">
            
            <!-- Sequência de Mensagens -->
            <div style="margin-bottom: 20px;">
              <h5 style="font-size:14px; font-weight:600; color: var(--text-secondary); margin-bottom:15px;">Sequência de Envio:</h5>
              
              ${flow.messages.length === 0 
                ? `<p style="color:var(--text-secondary); font-size:13px; font-style:italic;">Nenhum passo adicionado nesta sequência ainda.</p>` 
                : `
                  <div style="display:flex; flex-direction:column; gap:15px;">
                    ${flow.messages.map(msg => `
                      <div class="flow-card-item" id="step-card-${flow.id}-${msg.id}">
                        
                        <!-- Modo de Exibição -->
                        <div class="step-display-mode">
                          <div class="flow-step-header">
                            <span>Passo ${msg.step_order}</span>
                            <span style="font-size:12px; color:var(--text-secondary); display:inline-flex; align-items:center;">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 3px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                              Atraso: ${msg.after_seconds} segundos
                            </span>
                          </div>
                          <div style="background-color:#f8fafc; border: 1px solid var(--border-light); padding:12px; font-size:14px; white-space:pre-wrap; line-height:1.5; margin-bottom:10px;">${escapeHtml(msg.message_text)}</div>
                          
                          ${msg.attachment_path 
                            ? `<div style="font-size:12px; color: var(--success); display:flex; align-items:center; gap:5px; margin-bottom:10px;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                                Anexo: <small style="color:var(--text-secondary);">${msg.attachment_path.split(/\/|\\/).pop()}</small>
                               </div>` 
                            : ''
                          }
                          
                          <div style="text-align:right; display:flex; justify-content:flex-end; gap:8px;">
                            <button onclick="enableEditMode(${flow.id}, ${msg.id})" class="btn btn-secondary btn-sm" style="padding:4px 8px; font-size:11px; display:inline-flex; align-items:center;">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 3px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                              Editar
                            </button>
                            <button onclick="deleteStep(${flow.id}, ${msg.id})" class="btn btn-danger btn-sm" style="padding:4px 8px; font-size:11px; display:inline-flex; align-items:center;">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 3px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                              Excluir Passo
                            </button>
                          </div>
                        </div>

                        <!-- Modo de Edição -->
                        <div class="step-edit-mode" style="display:none;">
                          <div class="form-group" style="margin-bottom: 12px;">
                            <label style="font-size:12px;">Texto da Mensagem (use <code>{{nameClient}}</code>)</label>
                            <textarea class="form-control edit-message-text" rows="3" required>${escapeHtml(msg.message_text)}</textarea>
                          </div>
                          <div class="form-group" style="margin-bottom: 15px;">
                            <label style="font-size:12px;">Atraso de Envio (segundos)</label>
                            <input type="number" class="form-control edit-after-seconds" value="${msg.after_seconds}" min="0" required>
                          </div>
                          <div style="text-align:right; display:flex; justify-content:flex-end; gap:8px;">
                            <button onclick="cancelEditMode(${flow.id}, ${msg.id})" class="btn btn-secondary btn-sm" style="padding:4px 8px; font-size:11px; display:inline-flex; align-items:center;">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 3px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                              Cancelar
                            </button>
                            <button onclick="saveStepEdit(${flow.id}, ${msg.id})" class="btn btn-primary btn-sm" style="padding:4px 8px; font-size:11px; display:inline-flex; align-items:center;">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 3px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
                              Salvar
                            </button>
                          </div>
                        </div>

                      </div>
                    `).join('')}
                  </div>
                `
              }
            </div>

            <!-- Formulário para Adicionar Passo -->
            <div style="background-color:rgba(0,0,0,0.01); border: 1px dashed var(--border-light); padding:20px; margin-top:20px;">
              <h5 style="font-size:14px; font-weight:600; margin-bottom:15px; display:inline-flex; align-items:center;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Adicionar Passo à Sequência
              </h5>
              <form onsubmit="addStep(event, ${flow.id})">
                <div class="form-group">
                  <label>Texto da Mensagem (use <code>{{nameClient}}</code> para saudar o comprador)</label>
                  <textarea name="message_text" class="form-control" placeholder="Olá {{nameClient}} tudo bem? Aqui está o seu link..." required></textarea>
                </div>
                
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                  <div class="form-group">
                    <label>Atraso de Envio (segundos)</label>
                    <input type="number" name="after_seconds" class="form-control" value="10" min="0" required>
                  </div>
                  <div class="form-group">
                    <label>Imagem em Anexo (opcional)</label>
                    <input type="file" name="attachment" class="form-control" accept="image/*" style="padding:7px;">
                  </div>
                </div>

                <button type="submit" class="btn btn-secondary btn-sm" style="margin-top:10px; width:100%;">Adicionar Passo</button>
              </form>
            </div>

          </div>
        </div>
      `).join('');
    } catch (err) {
      flowsContainer.innerHTML = `<p style="text-align: center; color: var(--danger); padding: 40px 0;">Erro ao carregar fluxos.</p>`;
    }
  };

  // Helper para escapar HTML do texto
  const escapeHtml = (text) => {
    return text
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  };

  // Criar Fluxo
  createFlowForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const ml_account_id = document.getElementById('flow-account').value;
    const name = document.getElementById('flow-name').value;
    const product_id = document.getElementById('flow-product-id').value.trim();

    try {
      const response = await fetch('/api/flows', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ml_account_id, name, product_id })
      });

      if (!response.ok) throw new Error('Erro ao salvar fluxo.');
      
      showAlert('Fluxo criado com sucesso!');
      createFlowForm.reset();
      loadFlows();
    } catch (err) {
      showAlert(err.message, 'error');
    }
  });

  // Excluir Fluxo
  const deleteFlow = async (id) => {
    if (!confirm('Tem certeza que deseja excluir este fluxo e todos os seus passos?')) return;
    try {
      const response = await fetch(`/api/flows/${id}`, { method: 'DELETE' });
      if (!response.ok) throw new Error();
      showAlert('Fluxo excluído com sucesso!');
      loadFlows();
    } catch (err) {
      showAlert('Erro ao excluir fluxo.', 'error');
    }
  };

  // Adicionar Passo (Mensagem)
  const addStep = async (e, flowId) => {
    e.preventDefault();
    const form = e.target;
    const formData = new FormData(form);

    try {
      const response = await fetch(`/api/flows/${flowId}/messages`, {
        method: 'POST',
        body: formData // Envia o multipart/form-data com o multer
      });

      if (!response.ok) throw new Error();
      showAlert('Passo de mensagem adicionado!');
      form.reset();
      
      await loadFlows();
      
      // Abre o accordion correspondente após recarregar
      const itemToOpen = document.getElementById(`flow-item-${flowId}`);
      if (itemToOpen) {
        itemToOpen.classList.add('active');
      }
    } catch (err) {
      showAlert('Erro ao adicionar passo de mensagem.', 'error');
    }
  };

  // Excluir Passo
  const deleteStep = async (flowId, messageId) => {
    if (!confirm('Deseja realmente remover este passo? Os passos seguintes serão reordenados.')) return;
    try {
      const response = await fetch(`/api/flows/${flowId}/messages/${messageId}`, { method: 'DELETE' });
      if (!response.ok) throw new Error();
      showAlert('Passo de mensagem removido!');
      
      await loadFlows();
      
      // Abre o accordion correspondente após recarregar
      const itemToOpen = document.getElementById(`flow-item-${flowId}`);
      if (itemToOpen) {
        itemToOpen.classList.add('active');
      }
    } catch (err) {
      showAlert('Erro ao deletar passo.', 'error');
    }
  };

  // Edição Inline
  const enableEditMode = (flowId, messageId) => {
    const card = document.getElementById(`step-card-${flowId}-${messageId}`);
    if (card) {
      card.querySelector('.step-display-mode').style.display = 'none';
      card.querySelector('.step-edit-mode').style.display = 'block';
    }
  };

  const cancelEditMode = (flowId, messageId) => {
    const card = document.getElementById(`step-card-${flowId}-${messageId}`);
    if (card) {
      card.querySelector('.step-display-mode').style.display = 'block';
      card.querySelector('.step-edit-mode').style.display = 'none';
    }
  };

  const saveStepEdit = async (flowId, messageId) => {
    const card = document.getElementById(`step-card-${flowId}-${messageId}`);
    if (!card) return;
    
    const messageText = card.querySelector('.edit-message-text').value;
    const afterSeconds = card.querySelector('.edit-after-seconds').value;

    try {
      const response = await fetch(`/api/flows/${flowId}/messages/${messageId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message_text: messageText,
          after_seconds: Number(afterSeconds)
        })
      });

      if (!response.ok) throw new Error();
      
      showAlert('Passo de mensagem atualizado com sucesso!');
      
      await loadFlows();
      
      // Abre o accordion correspondente após recarregar
      const itemToOpen = document.getElementById(`flow-item-${flowId}`);
      if (itemToOpen) {
        itemToOpen.classList.add('active');
      }
    } catch (err) {
      showAlert('Erro ao atualizar o passo.', 'error');
    }
  };

  // Inicializar
  loadFlows();
</script>

<%- include('partials/footer') %>
